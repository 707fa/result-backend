# Django
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_CREDENTIALS=True
# Set True only for emergency/debug (not recommended for production):
CORS_ALLOW_ALL_ORIGINS=False
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# AI provider for Iman chat
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-pro,gemini-2.5-flash-lite
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY_MS=1200
AI_MAX_IMAGE_BYTES=5242880

# Optional fallback provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Subscription payment
SUBSCRIPTION_PRICE_UZS=99000
SUBSCRIPTION_DAYS=30
FRONTEND_BASE_URL=http://127.0.0.1:5188
PAYMENT_RETURN_URL=http://127.0.0.1:5188/student/subscription
# Required for production webhooks (use a long random value)
PAYMENT_WEBHOOK_SECRET=change_this_to_long_random_secret_64_chars
# Comma-separated student phones that always have full access (no payment required)
FREE_ACCESS_PHONES=+998978778177,+998909788255

# Payme
PAYME_MERCHANT_ID=

# Click
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=

# Telegram bot moderation for manual receipts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
TELEGRAM_BOT_SECRET=change_this_to_another_long_random_secret
